---
import Base from '../layouts/Base.astro';
import Opener from '../components/Opener.astro';

const findings = [
  {
    sev: 'critical',
    source: 'Hudson Rock · infostealer log',
    title: 'Credentials captured by infostealer malware',
    detail: '3 logins exfiltrated from an infected device, including a reused password.',
    fix: 'Rotate 3 passwords · enable 2FA · clean the device',
  },
  {
    sev: 'high',
    source: 'HIBP · credential breach',
    title: 'Password exposed in 2 known breaches',
    detail: 'The same password appears across two leaks tied to this email.',
    fix: 'Change the reused password · move to a manager',
  },
  {
    sev: 'low',
    source: 'Account enumeration',
    title: 'Email registered on 14 sites',
    detail: 'Mostly benign; three are dormant accounts worth closing.',
    fix: 'Close 3 dormant accounts',
  },
];

const categories = [
  { k: '01', t: 'Credential leaks', d: 'Breached passwords and the exact data classes exposed alongside them.' },
  { k: '02', t: 'Infostealer logs', d: 'Logins captured by malware — the highest-signal critical we surface.' },
  { k: '03', t: 'Account exposure', d: 'Where your email and usernames are registered across the web.' },
  { k: '04', t: 'Profile & identity', d: 'Public profiles and handles correlated into one identity graph.' },
  { k: '05', t: 'Account metadata', d: 'What your Google and linked accounts quietly give away.' },
  { k: '06', t: 'Infrastructure', d: 'Open services, ports, and CVEs tied to an IP you own.' },
];

const steps = [
  { n: '1', t: 'Add what you own', d: 'Name, username, email, photo, IP. Only inputs you can verify are yours.' },
  { n: '2', t: 'Arescope collects & judges', d: 'Connectors sweep OSINT sources; an LLM rates each finding info → critical and drops the noise.' },
  { n: '3', t: 'Fix what matters', d: 'A ranked action list: rotate this, remove that, opt out here, ordered by real risk.' },
];
---

<Base>
  <!-- ───────────────────────── nav ───────────────────────── -->
  <header class="nav">
    <div class="container nav-inner">
      <a class="brand" href="/" aria-label="Arescope home">
        <svg viewBox="0 0 32 32" width="26" height="26" aria-hidden="true">
          <circle cx="16" cy="16" r="8.5" fill="none" stroke="var(--accent-bright)"
                  stroke-width="2.4" stroke-dasharray="40 14" stroke-dashoffset="6"
                  stroke-linecap="round" transform="rotate(-45 16 16)" />
          <circle cx="16" cy="16" r="2.3" fill="var(--accent-bright)" />
        </svg>
        <span>Arescope</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#how">How it works</a>
        <a href="#finds">What it finds</a>
        <a href="#ethos">Self-audit</a>
      </nav>
      <a class="btn btn-primary nav-cta" href="#waitlist">Join the waitlist</a>
    </div>
  </header>

  <main>
    <!-- ───────────────────────── opener ───────────────────────── -->
    <Opener />

    <!-- ───────────────────────── how it works ───────────────────────── -->
    <section id="how" class="section">
      <div class="container">
        <header class="section-head reveal">
          <span class="eyebrow">How it works</span>
          <h2>Three steps from blind spot to fixed.</h2>
        </header>
        <ol class="steps">
          {
            steps.map((s) => (
              <li class="step reveal">
                <span class="step-n">{s.n}</span>
                <h3 class="step-t">{s.t}</h3>
                <p class="prose">{s.d}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ───────────────────────── what it finds ───────────────────────── -->
    <section id="finds" class="section">
      <div class="container">
        <header class="section-head reveal">
          <span class="eyebrow">What it finds</span>
          <h2>Six classes of exposure, one ranked report.</h2>
          <p class="prose">
            Each finding is normalized, deduplicated, and judged on its own
            merits, not handed to you as a raw data dump.
          </p>
        </header>
        <div class="cards">
          {
            categories.map((c) => (
              <article class="card cat reveal">
                <span class="cat-k">{c.k}</span>
                <h3 class="cat-t">{c.t}</h3>
                <p class="prose cat-d">{c.d}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── what a scan returns ───────────────────────── -->
    <section class="section">
      <div class="container">
        <header class="section-head reveal">
          <span class="eyebrow">What a scan returns</span>
          <h2>Severity you can act on, not an alarm.</h2>
          <p class="prose">
            Findings are ranked by real-world risk and paired with a concrete fix.
            Critical means do it now; low means it can wait.
          </p>
        </header>
        <div class="findings">
          {
            findings.map((f) => (
              <article class="card finding reveal">
                <div class="finding-top">
                  <span class={`chip chip-${f.sev}`}>
                    <i class="dot" />
                    {f.sev}
                  </span>
                  <span class="finding-src">{f.source}</span>
                </div>
                <h3 class="finding-title">{f.title}</h3>
                <p class="finding-detail">{f.detail}</p>
                <div class="finding-fix">
                  <span class="fix-label">Recommended fix</span>
                  <span class="fix-text">{f.fix}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── ethos ───────────────────────── -->
    <section id="ethos" class="section ethos">
      <div class="container ethos-grid">
        <header class="section-head reveal">
          <span class="eyebrow">The line we don't cross</span>
          <h2>Self-audit only. By design.</h2>
          <p class="prose">
            Arescope exists to shrink <em>your</em> footprint. It is not, and will
            never be, a people-search tool. That constraint is built into the
            data model, not a promise on a page.
          </p>
        </header>
        <ul class="ethos-points">
          <li class="reveal">
            <h3>Ownership-verified inputs</h3>
            <p class="prose">
              Email via magic link, accounts via OAuth, IP matched to your
              connection. You can only scan what you can prove is yours.
            </p>
          </li>
          <li class="reveal">
            <h3>Encrypted, then forgotten</h3>
            <p class="prose">
              PII is encrypted at rest and expires on a retention clock. We hold
              the minimum, for the minimum time.
            </p>
          </li>
          <li class="reveal">
            <h3>No investigation features</h3>
            <p class="prose">
              No lookups on other people, ever. The ownership gate is mandatory,
              not a setting.
            </p>
          </li>
        </ul>
      </div>
    </section>

    <!-- ───────────────────────── waitlist ───────────────────────── -->
    <section id="waitlist" class="section waitlist">
      <div class="container waitlist-inner reveal">
        <span class="eyebrow">Early access</span>
        <h2>Find out what's exposed.</h2>
        <p class="prose">
          Arescope is in build. Join the waitlist and we'll send one email when
          scans open.
        </p>
        <form class="waitlist-form" method="post" action="#" onsubmit="return false;">
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            aria-label="Email address"
            autocomplete="email"
          />
          <button class="btn btn-primary" type="submit">Join the waitlist</button>
        </form>
        <p class="waitlist-fine">No spam. No sharing. One email, when it's ready.</p>
      </div>
    </section>
  </main>

  <!-- ───────────────────────── footer ───────────────────────── -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="brand">
        <svg viewBox="0 0 32 32" width="22" height="22" aria-hidden="true">
          <circle cx="16" cy="16" r="8.5" fill="none" stroke="var(--accent-dim)"
                  stroke-width="2.4" stroke-dasharray="40 14" stroke-dashoffset="6"
                  stroke-linecap="round" transform="rotate(-45 16 16)" />
          <circle cx="16" cy="16" r="2.3" fill="var(--accent-dim)" />
        </svg>
        <span>Arescope</span>
      </div>
      <p class="footer-tag">Personal exposure scanner · self-audit only</p>
      <p class="footer-copy">© 2026 Arescope</p>
    </div>
  </footer>
</Base>

<style>
  /* ───── nav ───── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in oklch, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--hairline);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 1.05rem;
  }
  .nav-links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
    font-size: var(--step--1);
    color: var(--muted);
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-cta {
    padding: 0.55em 1em;
    font-size: var(--step--1);
  }

  /* ───── hero ───── */
  .hero {
    position: relative;
    padding-top: clamp(3.5rem, 2rem + 7vw, 7rem);
    padding-bottom: clamp(3.5rem, 2rem + 7vw, 7rem);
    overflow: hidden;
  }
  .ambient {
    position: absolute;
    inset: -20% -10% auto auto;
    width: min(70vw, 820px);
    height: 620px;
    background: radial-gradient(
      45% 45% at 70% 30%,
      oklch(0.86 0.26 143 / 0.18),
      transparent 70%
    );
    filter: blur(20px);
    pointer-events: none;
    animation: drift 22s var(--ease) infinite alternate;
    will-change: transform;
  }
  @keyframes drift {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-4%, 5%, 0) scale(1.12);
    }
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
    align-items: center;
  }
  .hero h1 {
    font-size: var(--step-5);
    margin: 1.1rem 0 0;
  }
  .hero-sub {
    margin-top: 1.4rem;
    font-size: var(--step-1);
    max-width: 46ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .hero-note {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--faint);
  }
  .hero-note i {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--accent-dim);
  }
  .hero-card {
    justify-self: end;
    width: 100%;
    max-width: 420px;
  }

  /* ───── cards / findings ───── */
  .card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 1.4rem;
    transition: transform 0.18s var(--ease), border-color 0.18s var(--ease),
      background 0.18s var(--ease);
  }
  .finding {
    box-shadow: 0 30px 80px -40px oklch(0.86 0.26 143 / 0.35);
  }
  .finding-top {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.9rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3em 0.6em;
    border-radius: 999px;
    border: 1px solid var(--hairline-strong);
    color: var(--ink);
  }
  .chip .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .chip-critical {
    background: oklch(0.64 0.2 18 / 0.12);
    border-color: oklch(0.64 0.2 18 / 0.4);
  }
  .chip-critical .dot {
    background: var(--sev-critical);
  }
  .chip-high {
    background: oklch(0.78 0.15 70 / 0.12);
    border-color: oklch(0.78 0.15 70 / 0.4);
  }
  .chip-high .dot {
    background: var(--sev-high);
  }
  .chip-low {
    background: var(--surface-2);
  }
  .chip-low .dot {
    background: var(--sev-low);
  }
  .finding-src {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--faint);
  }
  .finding-title {
    font-size: var(--step-1);
    line-height: 1.2;
  }
  .finding-detail {
    color: var(--muted);
    margin-top: 0.5rem;
    font-size: var(--step--1);
  }
  .finding-fix {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--hairline);
  }
  .fix-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-bright);
  }
  .fix-text {
    font-size: var(--step--1);
    color: var(--ink);
  }

  /* ───── section scaffolding ───── */
  .section {
    padding-block: clamp(3.5rem, 2rem + 6vw, 6.5rem);
    border-top: 1px solid var(--hairline);
  }
  .section-head {
    max-width: 56ch;
    margin-bottom: clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  .section-head h2 {
    font-size: var(--step-3);
    margin-top: 0.9rem;
  }
  .section-head .prose {
    margin-top: 1rem;
  }

  /* ───── steps ───── */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .step {
    padding-top: 1.3rem;
    border-top: 1px solid var(--hairline-strong);
  }
  .step-n {
    font-family: var(--font-mono);
    font-size: var(--step-2);
    color: var(--accent-bright);
  }
  .step-t {
    font-size: var(--step-1);
    margin: 0.7rem 0 0.5rem;
  }

  /* ───── category grid ───── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .cat:hover {
    transform: translateY(-3px);
    border-color: var(--accent-dim);
    background: var(--surface-2);
  }
  .cat-k {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--faint);
  }
  .cat-t {
    font-size: var(--step-1);
    margin: 0.7rem 0 0.5rem;
  }
  .cat-d {
    font-size: var(--step--1);
  }

  /* ───── findings list ───── */
  .findings {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .findings .finding {
    box-shadow: none;
  }
  .findings .finding:hover {
    transform: translateY(-3px);
    border-color: var(--hairline-strong);
  }

  /* ───── ethos ───── */
  .ethos-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
    align-items: start;
  }
  .ethos-grid .section-head {
    margin-bottom: 0;
  }
  .ethos-points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.6rem;
  }
  .ethos-points li {
    padding-left: 1.2rem;
    border-left: 2px solid var(--accent-dim);
  }
  .ethos-points h3 {
    font-size: var(--step-1);
    margin-bottom: 0.4rem;
  }

  /* ───── waitlist ───── */
  .waitlist-inner {
    max-width: 620px;
    margin-inline: auto;
    text-align: center;
  }
  .waitlist-inner h2 {
    font-size: var(--step-4);
    margin: 0.9rem 0 0;
  }
  .waitlist-inner .prose {
    margin: 1rem auto 0;
  }
  .waitlist-form {
    display: flex;
    gap: 0.6rem;
    margin: 2rem auto 0;
    max-width: 460px;
  }
  .waitlist-form input {
    flex: 1;
    min-width: 0;
    background: var(--surface);
    border: 1px solid var(--hairline-strong);
    color: var(--ink);
    border-radius: var(--radius-sm);
    padding: 0.8em 1em;
    font: inherit;
    transition: border-color 0.16s var(--ease);
  }
  .waitlist-form input::placeholder {
    color: var(--faint);
  }
  .waitlist-form input:focus-visible {
    outline: none;
    border-color: var(--accent-bright);
    box-shadow: 0 0 0 3px oklch(0.86 0.26 143 / 0.30);
  }
  .waitlist-fine {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
    margin-top: 1.1rem;
  }

  /* ───── footer ───── */
  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: 2.5rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--faint);
    font-size: var(--step--1);
  }
  .footer .brand {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .footer-tag {
    font-family: var(--font-mono);
  }
  .footer-copy {
    margin-left: auto;
  }

  /* ───── stagger reveal ───── */
  .steps .step:nth-child(2),
  .cards .cat:nth-child(2),
  .findings .finding:nth-child(2),
  .ethos-points li:nth-child(2) {
    transition-delay: 0.08s;
  }
  .steps .step:nth-child(3),
  .cards .cat:nth-child(3),
  .findings .finding:nth-child(3),
  .ethos-points li:nth-child(3) {
    transition-delay: 0.16s;
  }
  .cards .cat:nth-child(n + 4) {
    transition-delay: 0.12s;
  }

  /* ───── responsive ───── */
  @media (max-width: 900px) {
    .hero-grid,
    .ethos-grid {
      grid-template-columns: 1fr;
    }
    .hero-card {
      justify-self: stretch;
      max-width: 100%;
      order: -1;
    }
    .steps,
    .cards,
    .findings {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .nav-links {
      display: none;
    }
    .steps,
    .cards,
    .findings {
      grid-template-columns: 1fr;
    }
    .waitlist-form {
      flex-direction: column;
    }
  }
</style>
