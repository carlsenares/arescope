---
// The hero globe. A slowly Y-spinning dotted sphere with real continents
// (land-point cloud sampled from an equirectangular mask at build time).
//
// One-time intro, deliberately paced:
//   1. continent dots + red datapoint nodes appear (~0–1.3s)
//   2. brief pause
//   3. a network GRAPH draws on slowly (~1.5–3.8s): a connected spanning tree
//      plus a few long cross-ocean links. Straight geodesic lines that lie flat
//      on the sphere surface — not bouncy arcs. It's a graph, not a mesh: the
//      tree has no cycles, so no triangulated cells.
// After the intro the finished graph just rides the spin (lines are static on
// the surface and never re-draw). Constant size; no scroll coupling.
// Static settled frame under prefers-reduced-motion.
---

<canvas class="globe-canvas" aria-hidden="true"></canvas>

<style>
  .globe-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1s var(--ease);
  }
  .globe-canvas.is-live {
    opacity: 1;
  }
</style>

<script>
  import rawPoints from '../data/globe-points.json';

  const canvas = document.querySelector<HTMLCanvasElement>('.globe-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const points = rawPoints as [number, number][];
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const DEG = Math.PI / 180;
    const TILT = 0.42;

    type V = { x: number; y: number; z: number };

    // ---- palette ----
    const LAND = '190, 215, 200';
    const GRID = '120, 240, 110';
    const RED = '255, 52, 52';

    // ---- intro timeline (ms) — dots first, then a slow line draw ----
    const NODES = 46;
    const NODE_SPREAD = 900; // red nodes finish popping ~1.3s
    const NODE_DUR = 420;
    const LINE_START = 1500; // pause after dots, then lines begin
    const LINE_SPREAD = 1300; // edges staggered across this window
    const EDGE_DUR = 1000; // each line draws slowly
    const RK = 0.3; // constant radius factor (smaller than before)

    // ---- land base vectors ----
    const land: V[] = points.map(([lat, lng]) => {
      const la = lat * DEG;
      const lo = lng * DEG;
      const cl = Math.cos(la);
      return { x: cl * Math.cos(lo), y: Math.sin(la), z: cl * Math.sin(lo) };
    });

    const dot = (a: V, b: V) => a.x * b.x + a.y * b.y + a.z * b.z;
    const d2 = (a: V, b: V) => (a.x - b.x) ** 2 + (a.y - b.y) ** 2 + (a.z - b.z) ** 2;
    const angle = (a: V, b: V) => Math.acos(Math.max(-1, Math.min(1, dot(a, b))));

    // Farthest-point sampling → nodes spread evenly across every continent.
    function pickNodes(n: number): number[] {
      const start = (Math.random() * land.length) | 0;
      const chosen = [start];
      const mind = land.map((p) => d2(p, land[start]));
      while (chosen.length < n) {
        let bi = 0;
        let bv = -1;
        for (let i = 0; i < land.length; i++)
          if (mind[i] > bv) {
            bv = mind[i];
            bi = i;
          }
        chosen.push(bi);
        for (let i = 0; i < land.length; i++) {
          const d = d2(land[i], land[bi]);
          if (d < mind[i]) mind[i] = d;
        }
      }
      return chosen;
    }

    // Geodesic samples between two unit vectors, resolution scaled to arc length
    // so long lines stay smooth (no visible re-tessellation while spinning).
    function slerp(a: V, b: V): V[] {
      const th = angle(a, b);
      const st = Math.sin(th);
      const seg = Math.max(10, Math.min(64, Math.round(th / 0.1)));
      const pts: V[] = [];
      for (let i = 0; i <= seg; i++) {
        const t = i / seg;
        let s1: number;
        let s2: number;
        if (st < 1e-4) {
          s1 = 1 - t;
          s2 = t;
        } else {
          s1 = Math.sin((1 - t) * th) / st;
          s2 = Math.sin(t * th) / st;
        }
        pts.push({ x: a.x * s1 + b.x * s2, y: a.y * s1 + b.y * s2, z: a.z * s1 + b.z * s2 });
      }
      return pts;
    }

    const nodeIdx = pickNodes(NODES);
    const nodeV = nodeIdx.map((i) => land[i]);
    const nodeDelay = nodeV.map((_, i) => (i / NODES) * NODE_SPREAD);

    // ---- build a graph (not a mesh) ----
    // Spanning tree: attach each node (added in farthest-point order, so each is
    // far from the rest) to a connected node — mostly the nearest, sometimes a
    // random one, giving long hops. No cycles → reads as a graph, not cells.
    type RawEdge = { a: number; b: number };
    const raw: RawEdge[] = [];
    const seenEdge = new Set<string>();
    const key = (a: number, b: number) => (a < b ? `${a}-${b}` : `${b}-${a}`);
    const conn = [0];
    for (let i = 1; i < NODES; i++) {
      let target = conn[0];
      if (Math.random() < 0.62) {
        let bd = Infinity;
        for (const j of conn) {
          const d = d2(nodeV[i], nodeV[j]);
          if (d < bd) {
            bd = d;
            target = j;
          }
        }
      } else {
        target = conn[(Math.random() * conn.length) | 0]; // long hop
      }
      raw.push({ a: i, b: target });
      seenEdge.add(key(i, target));
      conn.push(i);
    }
    // a handful of long cross-ocean links to emphasise global connectivity
    let added = 0;
    for (let t = 0; t < 300 && added < 7; t++) {
      const a = (Math.random() * NODES) | 0;
      const b = (Math.random() * NODES) | 0;
      if (a === b || seenEdge.has(key(a, b))) continue;
      if (angle(nodeV[a], nodeV[b]) < 1.45) continue; // require a genuinely long span
      raw.push({ a, b });
      seenEdge.add(key(a, b));
      added++;
    }

    type Edge = { a: number; b: number; pts: V[]; delay: number };
    const NE = raw.length;
    const edges: Edge[] = raw.map((e, idx) => ({
      a: e.a,
      b: e.b,
      pts: slerp(nodeV[e.a], nodeV[e.b]),
      delay: LINE_START + (idx / NE) * LINE_SPREAD,
    }));

    // ---- viewport (constant size) ----
    let W = 0;
    let H = 0;
    let cx = 0;
    let cy = 0;
    let R = 0;
    const DPR = Math.min(devicePixelRatio || 1, 2);

    function metrics() {
      const r = canvas!.getBoundingClientRect();
      W = Math.max(1, r.width);
      H = Math.max(1, r.height);
      canvas!.width = Math.round(W * DPR);
      canvas!.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      cx = W / 2;
      cy = H / 2;
      R = Math.min(W, H) * RK;
    }

    // ---- rotation ----
    let spin = -0.5;
    function rot(v: V): V {
      const cs = Math.cos(spin);
      const sn = Math.sin(spin);
      const x = v.x * cs + v.z * sn;
      const z = -v.x * sn + v.z * cs;
      const ct = Math.cos(TILT);
      const st = Math.sin(TILT);
      return { x, y: v.y * ct - z * st, z: v.y * st + z * ct };
    }

    const clamp01 = (t: number) => (t < 0 ? 0 : t > 1 ? 1 : t);
    const easeOut = (t: number) => 1 - (1 - t) ** 3;
    const smooth = (t: number) => t * t * (3 - 2 * t);

    function strokePoly(rp: { x: number; y: number; vis: boolean }[]) {
      ctx.beginPath();
      let pen = false;
      for (const p of rp) {
        if (p.vis) {
          if (!pen) {
            ctx.moveTo(p.x, p.y);
            pen = true;
          } else ctx.lineTo(p.x, p.y);
        } else pen = false;
      }
      ctx.stroke();
    }

    function drawEdge(e: Edge, now: number) {
      const p = smooth(clamp01((now - e.delay) / EDGE_DUR));
      if (p <= 0) return;
      const seg = e.pts.length - 1;
      const upto = Math.max(1, Math.round(seg * p));
      const rp: { x: number; y: number; vis: boolean }[] = [];
      for (let i = 0; i <= upto; i++) {
        const r = rot(e.pts[i]);
        rp.push({ x: cx + r.x * R, y: cy - r.y * R, vis: r.z > 0.02 });
      }
      ctx.save();
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.shadowColor = `rgba(${RED}, 0.9)`;
      ctx.shadowBlur = 9;
      ctx.strokeStyle = `rgba(${RED}, 0.16)`;
      ctx.lineWidth = Math.max(3.5, R * 0.022);
      strokePoly(rp);
      ctx.shadowBlur = 5;
      ctx.strokeStyle = `rgba(${RED}, 0.92)`;
      ctx.lineWidth = Math.max(1.9, R * 0.011);
      strokePoly(rp);
      ctx.restore();
    }

    function drawNode(i: number, now: number) {
      const t = easeOut(clamp01((now - nodeDelay[i]) / NODE_DUR));
      if (t <= 0) return;
      const r = rot(nodeV[i]);
      if (r.z <= 0) return;
      const depth = r.z;
      const a = t * Math.min(1, (r.z + 0.1) / 0.3);
      const x = cx + r.x * R;
      const y = cy - r.y * R;
      ctx.save();
      ctx.shadowColor = `rgba(${RED}, ${a})`;
      ctx.shadowBlur = 12;
      ctx.fillStyle = `rgba(${RED}, ${a})`;
      ctx.beginPath();
      ctx.arc(x, y, (2.4 + 1.9 * depth) * t, 0, 7);
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.fillStyle = `rgba(255, 210, 210, ${a * 0.9})`;
      ctx.beginPath();
      ctx.arc(x, y, (0.9 + 0.7 * depth) * t, 0, 7);
      ctx.fill();
      ctx.restore();
    }

    function drawRing(kind: 'm' | 'p', deg: number) {
      ctx.beginPath();
      let pen = false;
      for (let t = 0; t <= 360; t += 6) {
        const a = t * DEG;
        let v: V;
        if (kind === 'm') {
          const lo = deg * DEG;
          v = { x: Math.cos(a) * Math.cos(lo), y: Math.sin(a), z: Math.cos(a) * Math.sin(lo) };
        } else {
          const la = deg * DEG;
          const cl = Math.cos(la);
          v = { x: cl * Math.cos(a), y: Math.sin(la), z: cl * Math.sin(a) };
        }
        const r = rot(v);
        if (r.z <= 0) {
          pen = false;
          continue;
        }
        const x = cx + r.x * R;
        const y = cy - r.y * R;
        if (!pen) {
          ctx.moveTo(x, y);
          pen = true;
        } else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }
    function drawGraticule() {
      ctx.lineWidth = 1;
      ctx.strokeStyle = `rgba(${GRID}, 0.06)`;
      for (let lng = -150; lng <= 180; lng += 30) drawRing('m', lng);
      for (let lat = -60; lat <= 60; lat += 30) drawRing('p', lat);
    }

    function draw(now: number) {
      ctx.clearRect(0, 0, W, H);

      const halo = ctx.createRadialGradient(cx, cy, R * 0.85, cx, cy, R * 1.28);
      halo.addColorStop(0, `rgba(${GRID}, 0.10)`);
      halo.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = halo;
      ctx.beginPath();
      ctx.arc(cx, cy, R * 1.28, 0, 7);
      ctx.fill();

      const body = ctx.createRadialGradient(cx - R * 0.35, cy - R * 0.35, R * 0.1, cx, cy, R);
      body.addColorStop(0, 'rgba(22, 30, 24, 0.95)');
      body.addColorStop(1, 'rgba(4, 6, 5, 0.98)');
      ctx.fillStyle = body;
      ctx.beginPath();
      ctx.arc(cx, cy, R, 0, 7);
      ctx.fill();

      drawGraticule();

      for (let i = 0; i < land.length; i++) {
        const r = rot(land[i]);
        if (r.z <= 0.02) continue;
        const fade = clamp01((now - (i / land.length) * 500) / 600);
        if (fade <= 0) continue;
        const d = r.z;
        const size = 0.8 + 1.5 * d;
        ctx.fillStyle = `rgba(${LAND}, ${(0.16 + 0.55 * d) * fade})`;
        ctx.fillRect(cx + r.x * R - size / 2, cy - r.y * R - size / 2, size, size);
      }

      ctx.strokeStyle = `rgba(${GRID}, 0.18)`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(cx, cy, R, 0, 7);
      ctx.stroke();

      for (const e of edges) drawEdge(e, now);
      for (let i = 0; i < NODES; i++) drawNode(i, now);
    }

    // ---- run loop ----
    let running = false;
    let live = false;
    let raf = 0;
    let prev = 0;
    let clock = 0;

    function frame(ts: number) {
      if (!running) return;
      const dt = prev ? ts - prev : 16;
      prev = ts;
      clock += dt;
      spin += dt * 0.0001;
      draw(clock);
      if (!live) {
        live = true;
        canvas!.classList.add('is-live');
      }
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (running) return;
      running = true;
      prev = 0;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    metrics();
    let rt: number;

    if (reduce) {
      const render = () => draw(99999);
      render();
      canvas.classList.add('is-live');
      addEventListener('resize', () => {
        clearTimeout(rt);
        rt = window.setTimeout(() => {
          metrics();
          render();
        }, 150);
      });
    } else {
      addEventListener('resize', () => {
        clearTimeout(rt);
        rt = window.setTimeout(metrics, 150);
      });
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !document.hidden) start();
          else stop();
        },
        { threshold: 0 }
      );
      io.observe(canvas);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else if (canvas.getBoundingClientRect().bottom > 0) start();
      });
      start();
    }
  }
</script>
