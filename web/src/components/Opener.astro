---
// The opener: a full-viewport globe plays its intro; once it settles the brand
// (top-left, in the nav) and then this tagline fade in. Text is kept legible
// over the globe by a soft radial vignette.
import Globe from './Globe.astro';
---

<section class="opener">
  <Globe />
  <div class="opener-vignette" aria-hidden="true"></div>

  <div class="opener-inner">
    <h1 class="tagline">
      <span style="--i:0">Protect</span>
      <span style="--i:1">your</span>
      <span style="--i:2">privacy.</span>
    </h1>
  </div>

  <a class="scroll-cue" href="#how" aria-label="Scroll to learn more">
    <span>scroll</span>
    <i></i>
  </a>
</section>

<style>
  .opener {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  /* darkens the globe directly behind the tagline so it stays legible */
  .opener-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 48% 32% at 50% 56%,
      oklch(0 0 0 / 0.74) 0%,
      oklch(0 0 0 / 0.4) 45%,
      transparent 72%
    );
    pointer-events: none;
  }

  .opener-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--gutter);
    /* nudge below the globe's equator so the wordmark/network breathe above */
    margin-top: clamp(2rem, 8vh, 6rem);
  }

  /* ---- tagline (appears after the brand reveal) ---- */
  .tagline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 1.4rem + 4.6vw, 5rem);
    font-weight: 650;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0;
  }
  .tagline span {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: rise 0.7s var(--ease) forwards;
    animation-delay: calc(3.4s + var(--i) * 0.1s);
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ---- scroll cue ---- */
  .scroll-cue {
    position: absolute;
    z-index: 2;
    bottom: clamp(1.2rem, 3vh, 2.4rem);
    left: 50%;
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--faint);
    opacity: 0;
    animation: rise 0.7s var(--ease) 4s forwards;
  }
  .scroll-cue:hover {
    color: var(--muted);
  }
  .scroll-cue i {
    width: 1px;
    height: 34px;
    background: linear-gradient(var(--accent-bright), transparent);
    animation: cue 1.8s var(--ease) 4.4s infinite;
    transform-origin: top;
  }
  @keyframes cue {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.5);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tagline span,
    .scroll-cue,
    .scroll-cue i {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
