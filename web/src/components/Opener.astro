---
// The opener: a full-viewport globe plays its intro; once it settles the brand
// (top-left, in the nav) and then this tagline fade in. Text is kept legible
// over the globe by a soft radial vignette.
import Globe from './Globe.astro';
---

<section class="opener">
  <Globe />
  <div class="opener-vignette" aria-hidden="true"></div>

  <div class="opener-inner">
    <h1 class="tagline">See what the internet knows about you.</h1>
  </div>

  <a class="scroll-cue" href="#how" aria-label="Scroll to learn more">
    <span>scroll</span>
    <i></i>
  </a>
</section>

<style>
  .opener {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  /* darkens the globe directly behind the tagline so it stays legible */
  .opener-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 34% 24% at 50% 50%,
      oklch(0 0 0 / 0.72) 0%,
      oklch(0 0 0 / 0.35) 50%,
      transparent 75%
    );
    pointer-events: none;
  }

  .opener-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--gutter);
  }

  /* ---- slogan: a restrained subhead so the globe stays the hero; rises in
     after the wordmark finishes writing ---- */
  .tagline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 auto;
    max-width: 16ch;
    text-shadow: 0 2px 24px oklch(0 0 0 / 0.7);
    opacity: 0;
    transform: translateY(18px);
    animation: rise 0.8s var(--ease) 4.9s forwards;
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ---- scroll cue ---- */
  .scroll-cue {
    position: absolute;
    z-index: 2;
    bottom: clamp(1.2rem, 3vh, 2.4rem);
    left: 50%;
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--faint);
    opacity: 0;
    animation: rise 0.7s var(--ease) 5.5s forwards;
  }
  .scroll-cue:hover {
    color: var(--muted);
  }
  .scroll-cue i {
    width: 1px;
    height: 34px;
    background: linear-gradient(var(--accent-bright), transparent);
    animation: cue 1.8s var(--ease) 5.9s infinite;
    transform-origin: top;
  }
  @keyframes cue {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.5);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tagline,
    .scroll-cue,
    .scroll-cue i {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
