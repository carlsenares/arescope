---
// The opener: a full-viewport globe forms (its graph grows organically); near
// the tail of that intro the masthead arrives over it.
//
// Centered masthead "ARESCOPE": true SVG vector outlines (dark toxic-green
// frame, wide HUD tracking so strokes never touch — clean), lit by a single
// green scan beam that sweeps through like a scanner pass, with two diagonal
// reticle corner brackets framing it like a viewfinder. The product is a
// "scope" — the wordmark behaves like one.
//
// Then the slogan reveals word-by-word down the vertical middle ("you" decrypts
// in matrix-green), and the two CTAs follow. Auth sits top-right.
// No nav bar, no scroll cue. Dependency-free; the static Astro build stays.
import Globe from './Globe.astro';
---

<section class="opener">
  <Globe />
  <div class="opener-vignette" aria-hidden="true"></div>

  <!-- top-right auth: log in is "on the wall", sign up is the prominent pill -->
  <nav class="auth" aria-label="Account">
    <a class="auth-login" href="#login">Log in</a>
    <a class="auth-signup" href="#signup">Sign up</a>
  </nav>

  <div class="opener-inner">
    <!-- centered masthead -->
    <h1 class="wordmark" aria-label="Arescope">
      <span class="brand">
        <!-- ONE outline only (no second layer = no doubled edges). The single
             moving light is a bright band inside the stroke's gradient that
             sweeps across the word, same technique as the ACET reference. -->
        <svg class="brand-svg" viewBox="-8 -703 5880 747" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <linearGradient id="ares-sweep" gradientUnits="objectBoundingBox" x1="0" y1="0" x2="1" y2="0">
              <stop class="g-dim" offset="0" />
              <stop class="g-dim" offset="0.4" />
              <stop class="g-lit" offset="0.5" />
              <stop class="g-dim" offset="0.6" />
              <stop class="g-dim" offset="1" />
              <animateTransform attributeName="gradientTransform" type="translate" from="-1 0" to="1 0" dur="4.5s" begin="4s" repeatCount="indefinite" />
            </linearGradient>
          </defs>
