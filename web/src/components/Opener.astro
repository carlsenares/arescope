        </svg>
      </span>
    </h1>

    <!-- slogan reveals word-by-word, then the CTAs -->
    <div class="lede">
      <p class="tagline">
        <span class="w">What</span> <span class="w">the</span> <span class="w">internet</span>
        <span class="w">knows</span> <span class="w">about</span>
        <span class="w"><span class="enc">you</span>.</span>
      </p>

      <div class="actions">
        <a class="cta cta-primary" href="#start">Start analysis</a>
        <a class="cta cta-secondary" href="#about">About</a>
      </div>
    </div>
  </div>
</section>

<style>
  .opener {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
  }

  /* darken the central column so the centered chrome stays legible over the globe */
  .opener-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 58% 82% at 50% 46%,
      oklch(0 0 0 / 0.62) 0%,
      oklch(0 0 0 / 0.28) 40%,
      transparent 72%
    );
    pointer-events: none;
  }

  /* ───── top-right auth ───── */
  .auth {
    position: absolute;
    z-index: 3;
    top: clamp(1.2rem, 3.5vh, 2rem);
    right: var(--gutter);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fade 0.6s var(--ease) 4s forwards;
  }
  .auth-login {
    padding: 0.55em 0.9em;
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--muted);
    border-radius: var(--radius-sm);
    transition: color 0.16s var(--ease);
  }
  .auth-login:hover {
    color: var(--ink);
  }
  .auth-signup {
    padding: 0.55em 1.05em;
    font-size: var(--step--1);
    font-weight: 600;
    color: oklch(0.08 0 0);
    background: var(--ink);
    border-radius: var(--radius-sm);
    transition: transform 0.16s var(--ease), box-shadow 0.16s var(--ease),
      background 0.16s var(--ease);
  }
  .auth-signup:hover {
    transform: translateY(-1px);
    background: #fff;
    box-shadow: 0 8px 24px -10px oklch(1 0 0 / 0.5);
  }

  /* ───── centered hero scaffold ───── */
  .opener-inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: clamp(2.25rem, 7vh, 4.5rem) var(--gutter) clamp(3rem, 11vh, 6.5rem);
  }

  /* ---- masthead: clean SVG outlines + scan beam + reticle brackets ---- */
  .wordmark {
    margin: 0;
    line-height: 1;
    opacity: 0;
    animation: fade 0.9s var(--ease) 3.4s forwards;
  }
  .brand {
    position: relative;
    display: block;
    width: min(78vw, 820px);
  }
  /* diagonal reticle corner brackets (viewfinder framing) */
  .brand::before,
  .brand::after {
    content: '';
    position: absolute;
    width: clamp(14px, 2vw, 22px);
    height: clamp(14px, 2vw, 22px);
    border: 1.6px solid var(--accent-dim);
    opacity: 0.7;
    pointer-events: none;
  }
  .brand::before {
    top: -0.7rem;
    left: -1rem;
    border-right: 0;
    border-bottom: 0;
  }
  .brand::after {
    right: -1rem;
    bottom: -0.7rem;
    border-left: 0;
    border-top: 0;
  }
  .brand-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }
  .brand-svg path {
    fill: none;
    stroke: url(#ares-sweep); /* single merged outline; the gradient carries the moving light */
    stroke-width: 11.8; /* font-unit space (viewBox ~5880 wide) → ~1.8px on screen */
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  .g-dim {
    stop-color: var(--accent-deep); /* dark toxic-green frame */
  }
  .g-lit {
    stop-color: var(--accent-bright); /* the travelling light */
  }

  /* ---- lede: vertically centered in the space below the masthead ---- */
  .lede {
    margin-block: auto;
  }
  .tagline {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.1rem + 2.2vw, 2.9rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.18;
    max-width: 18ch;
    margin-inline: auto;
    color: var(--ink);
    text-shadow: 0 1px 22px oklch(0 0 0 / 0.7);
  }
  /* each word rises in, one after another */
  .tagline .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: rise 0.6s var(--ease) forwards;
  }
  .tagline .w:nth-child(1) {
    animation-delay: 4.7s;
  }
  .tagline .w:nth-child(2) {
    animation-delay: 4.92s;
  }
  .tagline .w:nth-child(3) {
    animation-delay: 5.14s;
  }
  .tagline .w:nth-child(4) {
    animation-delay: 5.36s;
  }
  .tagline .w:nth-child(5) {
    animation-delay: 5.58s;
  }
  .tagline .w:nth-child(6) {
    animation-delay: 5.8s;
  }
  .tagline .enc {
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0;
    color: var(--matrix);
    text-shadow: 0 0 16px var(--matrix-glow);
    font-variant-numeric: tabular-nums; /* stable width while scrambling */
  }

  /* ---- CTAs: one flat-green action, one neutral ghost ---- */
  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: clamp(2rem, 1rem + 2.5vw, 3.2rem);
    opacity: 0;
    transform: translateY(12px);
    animation: rise 0.7s var(--ease) 6.6s forwards;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--step-0);
    font-weight: 600;
    line-height: 1;
    padding: 0.9em 1.6em;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    transition: transform 0.16s var(--ease), box-shadow 0.16s var(--ease),
      background 0.16s var(--ease), border-color 0.16s var(--ease),
      color 0.16s var(--ease);
  }
  .cta-primary {
    color: oklch(0.08 0 0);
    background: var(--matrix);
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    background: var(--accent-bright);
    box-shadow: 0 12px 36px -14px var(--matrix-glow);
  }
  .cta-secondary {
    color: var(--ink);
    background: transparent;
    border-color: var(--hairline-strong);
  }
  .cta-secondary:hover {
    transform: translateY(-1px);
    border-color: var(--accent-dim);
    background: oklch(1 0 0 / 0.04);
  }

  @keyframes fade {
    to {
      opacity: 1;
    }
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .brand {
      width: min(90vw, 820px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wordmark,
    .tagline .w,
    .actions,
    .auth {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<script>
  // Decrypt the slogan's final word in place. Hand-rolled (no dependencies) so
  // the static Astro build stays as-is. Starts scrambled, settles left→right,
  // and re-runs on hover. Skipped entirely under reduced motion.
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Under reduced motion, freeze the wordmark's scan (SMIL ignores the CSS
  // media query) so the light holds mid-word instead of travelling.
  if (reduce) {
    const brandSvg = document.querySelector<SVGSVGElement>('.brand-svg');
    brandSvg?.pauseAnimations?.();
  }

  const enc = document.querySelector<HTMLElement>('.tagline .enc');
  if (enc && !reduce) {
    const final = enc.textContent ?? '';
    const glyphs = '!<>-_\\/[]{}=+*^?#01';
    const rand = () =>
      Array.from(final, () => glyphs[(Math.random() * glyphs.length) | 0]).join('');

    let timer = 0;
    function decode() {
      clearInterval(timer);
      const total = 22;
      const settle = Array.from(final, (_, i) =>
        Math.round(((i + 1) / final.length) * total * 0.7 + Math.random() * total * 0.3)
      );
      let frame = 0;
      timer = window.setInterval(() => {
        let out = '';
        for (let i = 0; i < final.length; i++)
          out += frame >= settle[i] ? final[i] : glyphs[(Math.random() * glyphs.length) | 0];
        enc!.textContent = out;
        if (frame++ >= total) {
          clearInterval(timer);
          enc!.textContent = final;
        }
      }, 45);
    }

    enc.textContent = rand(); // avoid flashing the plain word before its word rises in
    setTimeout(decode, 6300); // just after the last word ("you.") has risen in
    enc.addEventListener('mouseenter', decode);
  }
</script>
