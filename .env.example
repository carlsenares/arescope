# Arescope configuration — copy to .env (gitignored) and fill in.
# Every connector degrades gracefully: a missing key logs a coverage gap,
# it never fails the scan. So you can run with only a subset of these set.

# --- Core infra ---
ARESCOPE_DATABASE_URL=postgresql+psycopg://arescope:arescope@localhost:5432/arescope
ARESCOPE_REDIS_URL=redis://localhost:6379/0

# --- PII encryption (required) ---
# 32-byte urlsafe-base64 Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ARESCOPE_ENCRYPTION_KEY=

# --- LLM (judge + remediation) ---
ANTHROPIC_API_KEY=
# Tiered models (see docs/AI_PIPELINE.md): Haiku triages everything, Opus judges + remediates.
ARESCOPE_TRIAGE_MODEL=claude-haiku-4-5
ARESCOPE_JUDGE_MODEL=claude-opus-4-8
ARESCOPE_REMEDIATION_MODEL=claude-opus-4-8

# --- Retention ---
ARESCOPE_RETENTION_DAYS=30

# --- Web app + auth (self-hosted accounts) ---
# Signs the session cookie. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ARESCOPE_SESSION_SECRET=dev-insecure-change-me
ARESCOPE_SESSION_MAX_AGE=1209600   # 14 days
ARESCOPE_COOKIE_SECURE=false       # set true behind HTTPS in production
ARESCOPE_BASE_URL=http://localhost:8000

# Admin seed — consumed by `python -m arescope.manage create-admin`.
ARESCOPE_ADMIN_EMAIL=
ARESCOPE_ADMIN_USERNAME=
ARESCOPE_ADMIN_PASSWORD=

# --- Outbound email (magic-link login + signup verification) ---
# Provider: Resend (https://resend.com). Free tier ~3,000/mo. If unset, the mailer
# logs links to the console instead of sending (fine for local dev).
ARESCOPE_RESEND_API_KEY=
# Must be an address on a domain you've verified in Resend.
ARESCOPE_EMAIL_FROM=Arescope <noreply@arescope.com>
ARESCOPE_MAGIC_LINK_TTL_MINUTES=30

# --- Connectors (all optional; absent key => coverage gap, not failure) ---
# HIBP: paid API key (~cheap monthly) — https://haveibeenpwned.com/API/Key
ARESCOPE_HIBP_API_KEY=
# Hudson Rock Cavalier: free tier, no key needed. Toggle off to skip.
ARESCOPE_HUDSONROCK_ENABLED=true
# Holehe / Maigret: free self-hosted Python libs, no key. Toggle to skip.
ARESCOPE_HOLEHE_ENABLED=true
ARESCOPE_MAIGRET_ENABLED=true
# Shodan: optional, for IP infrastructure scans — https://shodan.io
ARESCOPE_SHODAN_API_KEY=
# Name → data-broker / people-search listings (root input: name). Provider-agnostic:
# point this at your chosen people-search/broker API (or a thin shim you host) that
# answers POST {name, extended} -> {listings:[{broker,domain,listing_url,opt_out_url,
# match_confidence,details}]}. Absent => name stays an honest coverage gap. Returns
# listing existence + opt-out links (the removal track); the full dossier is the gated
# extended tier (name + verified email — see docs/OWNERSHIP_VERIFICATION.md), built next.
ARESCOPE_NAME_SEARCH_API_URL=
ARESCOPE_NAME_SEARCH_API_KEY=

# IntelX (Intelligence X) — email/username/name/phone/IP -> leaks, pastes, leaked docs,
# darkweb mentions. admin-only. Get a key at https://intelx.io/account?tab=developer.
# Free-tier keys use the host https://free.intelx.io (see connectors/intelx.py _BASE).
ARESCOPE_INTELX_API_KEY=
